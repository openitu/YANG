    }
    container bidirectional-dm-data {
      when "derived-from-or-self(../../../tp-oam:oam-type,
            'tp-oam:oam-dm')" {
        description
          "When the OAM type is DMM/DMR.";
      }
      description
        "The pro-active bidirectional delay measurement PM data.";
      uses dm-performance-data;
    }
  }

